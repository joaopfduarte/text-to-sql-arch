@startuml
left to right direction
skinparam backgroundColor transparent

rectangle "ExportRelacionalOffline" as dump
rectangle "ExtracaoSubconjunto" as extracao
rectangle "MascararPII" as mascarar
rectangle "ArquivosBronze" as bronze
database "HDFSDadosLaboratorioBronze" as hdfsBronze
rectangle "TabelasHiveExternas" as hiveExt
rectangle "RegistroNoApacheAtlas" as atlasReg
rectangle "ToolsMCPCatalog" as mcpTools
rectangle "ExecutorSQLJDBC" as jdbcExec
rectangle "HarnessExperimental" as harness
rectangle "AgenteLLM" as agente

dump --> extracao
extracao --> mascarar
mascarar --> bronze
bronze --> hdfsBronze
hdfsBronze --> hiveExt
hiveExt --> atlasReg
atlasReg --> mcpTools
hiveExt --> jdbcExec
jdbcExec --> harness
mcpTools --> agente
agente --> harness
@enduml
