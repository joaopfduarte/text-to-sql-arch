site/
public/
public-anonymous/
.gh-pages-worktree/
.vite-out/
dist/
.cache/
venv/
.venv/
__pycache__/
*.pyc
node_modules/
docs/assets/js/bundle.js
docs/assets/css/style.css

# Evita output acidental do MkDocs dentro de docs/assets/ (fonte do site)
docs/assets/*
!docs/assets/js/
!docs/assets/css/
!docs/assets/scripts/
docs/assets/js/*
!docs/assets/js/.gitkeep
docs/assets/css/*
!docs/assets/css/.gitkeep
docs/assets/scripts/*
!docs/assets/scripts/ODP-VDF.xml

# Symlinks gerados por scripts/prepare-docs.sh
/docs/evidence
/docs/templates
/docs/dados
/docs/diagrams/*.puml
/docs/diagrams/*.svg

# Dump MySQL versionado (nomes de coluna legados no DDL)
/dados/*
!dados/README.md
!dados/*.sql

# Bloquear reintrodução acidental de artefatos sensíveis
db-reference/
legacy-infra/
docs/monografia.pdf
**/putz_db.*
