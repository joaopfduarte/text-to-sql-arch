# Normalização global (CI GitLab + dev local)
* text=auto eol=lf

# Documentação e código-fonte
*.md            text diff=markdown linguist-detectable
*.{yml,yaml}    text
*.{json,lock}   text
*.{ts,js,mjs}   text linguist-detectable
*.{css,html}    text
*.py            text linguist-detectable
*.sh            text eol=lf
*.{puml,mmd}    text
*.svg           text
*.csv           text
*.xml           text
*.tf            text

# Binários
*.{png,jpg,jpeg,gif,webp,ico,pdf,woff,woff2} binary

# Artefactos gerados (não versionados; regras aplicam-se se existirem localmente)
docs/assets/js/bundle.js   -diff linguist-generated
docs/assets/css/style.css  -diff linguist-generated

# Output de build MkDocs — excluir de git archive
public/         export-ignore
site/           export-ignore
node_modules/   export-ignore
